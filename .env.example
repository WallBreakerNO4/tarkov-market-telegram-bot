TELEGRAM_BOT_TOKEN=
# 已迁移到 tarkov.dev（免费），无需 API Token；保留兼容旧配置
TARKOV_MARKET_API_TOKEN=
# 可选值: pvp(默认) 或 pve
END_POINT_TYPE=pvp

# 缓存后台刷新间隔（秒）；启动后会按该间隔从 API 全量刷新 SQLite 缓存
CACHE_REFRESH_INTERVAL_SECONDS=300

# 全量刷新时每次 GraphQL 请求之间的延迟（秒）；用于避免启动时 17 个 POST 的突发请求
CACHE_REFRESH_REQUEST_DELAY_SECONDS=0.2
